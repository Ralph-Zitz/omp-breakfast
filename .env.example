# Server configuration
SERVER__HOST=0.0.0.0
SERVER__PORT=8080
SERVER__SECRET=change-me-in-production
SERVER__JWTSECRET=change-me-in-production

# PostgreSQL configuration
PG__HOST=localhost
PG__PORT=5432
PG__USER=actix
PG__PASSWORD=actix
PG__DBNAME=actix
PG__POOL_MAX_SIZE=30
PG__SSL_MODE=Require

# TLS certificate for PostgreSQL connection
DB_CA_CERT=localhost_ca.pem

# Environment (development | production)
ENV=development
